# .env.example — 3R Assist
# All required environment keys. No values committed. Copy to .env and fill in.
# .env must be in .gitignore.

# ── LLM ──────────────────────────────────────────────
# Anthropic API key for protocol parameter extraction
ANTHROPIC_API_KEY=

# Anthropic model to use (e.g. claude-sonnet-4-20250514)
ANTHROPIC_MODEL=

# ── Embeddings ───────────────────────────────────────
# Model name when SEMANTIC_RANKING=true (requires requirements-ml.txt)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# false = filter/keyword ranking only (MVP default, no PyTorch on API)
# true  = cosine similarity via sentence-transformers (set on Render when ready)
SEMANTIC_RANKING=false

# ── Database ─────────────────────────────────────────
# PostgreSQL connection string (Neon branch or local instance)
# Apply schema: cd backend && python scripts/migrate.py
DATABASE_URL=

# ── Auth ─────────────────────────────────────────────
# Secret for magic-link email tokens (min 32 chars)
AUTH_SECRET=

# Email provider for magic-link delivery (TBD in M2 Phase B)
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=

# ── App ──────────────────────────────────────────────
# Environment: development | staging | production
APP_ENV=development
NODE_ENV=

# Public base URL (used in magic-link emails and CORS)
APP_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ── Frontend (see also frontend/.env.example) ────────
# VITE_API_BASE_URL=http://localhost:8000

# ── Add new keys here as they are identified in M2 ───
