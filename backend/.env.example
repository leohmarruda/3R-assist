# Copy to backend/.env — never commit real values

APP_ENV=development
APP_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# PostgreSQL (Neon branch or local instance). Run: python scripts/migrate.py
DATABASE_URL=postgresql://user:password@localhost:5432/3r_assist

# Leave empty to use StubLLMAdapter (local dev without API costs)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

EMBEDDING_MODEL=all-MiniLM-L6-v2

# false = filter/keyword ranking (MVP default); true = sentence-transformers on API
SEMANTIC_RANKING=false

AUTH_SECRET=
